# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4

[*.sh]
indent_size = 2
shell = bash

[Makefile]
indent_style = tab

[*.json]
indent_size = 2

[Dockerfile]
indent_size = 2

[*.{js,ts}]
indent_size = 2
quote_type = double

[*.{css,scss}]
indent_size = 2

[*.html]
indent_size = 2